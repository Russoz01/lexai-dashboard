NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3006
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Google Calendar OAuth (opcional — Rotina funciona sem)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lexai-ffinal.vercel.app/api/google/callback

# Sentry (observabilidade — mesmo DSN no client e no server)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Auth token para upload de source maps durante o build — gere em
# https://sentry.io/settings/account/api/auth-tokens/ com escopo "project:releases"
SENTRY_AUTH_TOKEN=

# Email transacional (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL="LexAI <onboarding@resend.dev>"

# Vercel Cron secret — usado para autenticar os jobs em /api/cron/*
# Gere com: openssl rand -hex 32
CRON_SECRET=

# Service-role key do Supabase (server-only, NUNCA expor ao client)
SUPABASE_SERVICE_ROLE_KEY=
